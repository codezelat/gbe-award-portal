{
  "name": "gbe-award-portal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
