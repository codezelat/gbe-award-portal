    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun --conditions=react-server scripts/seed.ts",
    "db:bootstrap-admin": "bun --conditions=react-server scripts/bootstrap-admin.ts",
    "db:studio": "drizzle-kit studio",
    "env:verify": "tsx scripts/verify-env.ts",
    "providers:verify": "bun --conditions=react-server scripts/verify-providers.ts",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
